# Infisical (vault) — copy to .env and fill. Do not commit the real .env.
# Generate the two crypto values:
#   INFISICAL_ENCRYPTION_KEY  -> openssl rand -hex 16   (exactly 32 chars; read as utf-8 = 32-byte AES-256 key)
#   INFISICAL_AUTH_SECRET     -> openssl rand -base64 32
# Losing INFISICAL_ENCRYPTION_KEY means losing every stored secret. Back it up
# separately from the Postgres dump.

INFISICAL_VERSION=latest

INFISICAL_ENCRYPTION_KEY=
INFISICAL_AUTH_SECRET=

VAULT_PG_USER=infisical
VAULT_PG_PASSWORD=
VAULT_PG_DB=infisical

VAULT_REDIS_PASSWORD=

SMTP_HOST=
DOMAIN=
